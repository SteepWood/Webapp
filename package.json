    "import:logo": "node scripts/import-brand-logo.mjs",
    "deploy:p0-images": "node scripts/deploy-images.mjs --priority=P0",
    "deploy:images": "node scripts/deploy-images.mjs",
    "upload:cms-images": "node scripts/upload-cms-images.mjs"
  },
