{
  "name": "steepwood-webapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:env": "dotenv -e .env.local -- tsx src/env.ts",
    "prisma:pull": "dotenv -e .env.local -- prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "setup:db": "tsx scripts/setup-supabase-env.ts",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:verify": "dotenv -e .env.local -- tsx scripts/verify-db.ts",
    "resend:verify": "dotenv -e .env.local -- tsx scripts/verify-resend.ts",
    "email:dns-check": "tsx scripts/check-email-dns.ts",
    "email:test-forms": "dotenv -e .env.local -- tsx scripts/test-form-emails.ts",
    "supabase:types": "supabase gen types typescript --project-id uqumesylnwumwxgoukpn --schema public > src/lib/supabase/database.types.ts",
    "audit:content": "tsx scripts/audit-content.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "snapshot:seo:pre": "node scripts/snapshot-seo.mjs pre",
