# SteepWood environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.
#
# Dashboard / DNS / bucket setup is deferred until after Phase 4 code.
# See docs/STEEPWOOD-MANUAL-OPS.md for the full production launch runbook.

# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key (Settings → API — recommended)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon JWT key (optional fallback if not using publishable key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase secret key (Settings → API — server only, never expose to the browser)
# Legacy name kept for compatibility: SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=

# Prisma pooled connection (Supabase → Connect → ORMs → Prisma → Transaction pooler, port 6543)
# Project uqumesylnwumwxgoukpn (ap-southeast-1). Run: pnpm setup:db
# postgresql://postgres.uqumesylnwumwxgoukpn:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Prisma direct connection for migrations (port 5432)
# postgresql://postgres:[PASSWORD]@db.uqumesylnwumwxgoukpn.supabase.co:5432/postgres
DIRECT_URL=

# Resend API key for transactional email (resend.com → API Keys)
RESEND_API_KEY=

# Sender address for outbound email (must be a verified Resend domain)
RESEND_FROM_EMAIL=hello@steepwood.com.au

# Inbox that receives new quote request notifications
QUOTE_NOTIFY_EMAIL=hello@steepwood.com.au

# Resend Audience — footer newsletter (Audience → Segments / Topics in dashboard)
RESEND_NEWSLETTER_SEGMENT_ID=c55c31c1-3efb-48e0-9abb-6d734abdbcf3
RESEND_NEWSLETTER_TOPIC_ID=e13b4f9e-96bb-432e-8d3d-3e24a42a2b3b

# Resend webhook signing secret (Resend dashboard → Webhooks → signing secret)
RESEND_WEBHOOK_SECRET=

# Vercel Cron authentication (Vercel project env — required for cron routes in production)
CRON_SECRET=

# Optional: base URL for pnpm smoke (defaults to http://localhost:3000)
SMOKE_TEST_URL=

# Resend DNS for steepwood.com.au (configure at your DNS provider):
# - DKIM: 3 CNAME records from Resend dashboard
# - SPF TXT: v=spf1 include:spf.resend.com -all
# - DMARC TXT: v=DMARC1; p=quarantine; rua=mailto:dmarc@steepwood.com.au;

# Public site URL used for canonical links, OG tags, and JSON-LD
NEXT_PUBLIC_SITE_URL=https://steepwood.com.au

# Google Analytics 4 measurement ID (optional — leave blank to disable)
NEXT_PUBLIC_GA4_ID=
